    "@fastify/swagger": "^8.14.0",
    "@fastify/swagger-ui": "^3.0.0",
    "@prisma/client": "^5.11.0",
    "@supabase/supabase-js": "^2.45.0",
    "axios": "^1.6.8",
    "bullmq": "^5.4.2",
    "dotenv": "^17.3.1",
    "fastify": "^4.26.2",
    "fastify-raw-body": "^4.3.0",
    "form-data": "^4.0.0",
    "googleapis": "^136.0.0",
    "ioredis": "^5.3.2",
    "openai": "^4.29.2",
    "pino": "^8.19.0",
    "pino-pretty": "^11.0.0",
